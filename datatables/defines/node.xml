<module name="">

	<enum name="NodePinType" comment="节点引脚类型">
		<var name="STRING" alias="文本" />
		<var name="NUMBER" alias="数值" />
		<var name="GAME_MODULE" alias="游戏模块" />
		<var name="GAME_BUTTON" alias="游戏按钮" />
		<var name="AUTO_GAME_BUTTON" alias="自动游戏按钮" />
		<var name="GAME_CAMPAIGN" alias="游戏副本" />
	</enum>

    <bean name="NodePin">
        <var name="type" type="NodePinType" comment="引脚类型" />
        <var name="name" type="string" comment="引脚名称" />
    </bean>

</module>